---
---

<section class="py-20 border-t border-border-subtle">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-12">Get started in 30 seconds</h2>

    <!-- Tab selector -->
    <div class="flex justify-center gap-2 mb-8">
      <button id="tab-openclaw" class="tab-btn tab-active px-4 py-2 rounded-md text-sm font-medium transition-colors" onclick="switchTab('openclaw')">
        OpenClaw
      </button>
      <button id="tab-npm" class="tab-btn px-4 py-2 rounded-md text-sm font-medium transition-colors text-text-secondary hover:text-text-primary" onclick="switchTab('npm')">
        npm / standalone
      </button>
    </div>

    <!-- OpenClaw tab -->
    <div id="panel-openclaw" class="tab-panel">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Install + init -->
        <div class="bg-code-bg border border-border-subtle rounded-lg overflow-hidden">
          <div class="px-4 py-2 border-b border-border-subtle">
            <span class="text-xs text-text-secondary font-mono">terminal</span>
          </div>
          <pre class="p-4 text-sm leading-relaxed"><code class="text-text-primary"><span class="text-text-secondary"># Install the plugin</span>
<span class="text-accent">openclaw</span> plugins install openclaw-plugin-edicts

<span class="text-text-secondary"># Restart the gateway</span>
<span class="text-accent">openclaw</span> gateway restart

<span class="text-text-secondary"># edicts.yaml is auto-created in your workspace</span>
<span class="text-text-secondary"># Start adding edicts:</span>
<span class="text-accent">edicts</span> add --text "v2.0 launches April 15" \
  --category product --confidence verified</code></pre>
        </div>

        <!-- YAML file -->
        <div class="bg-code-bg border border-border-subtle rounded-lg overflow-hidden">
          <div class="px-4 py-2 border-b border-border-subtle">
            <span class="text-xs text-text-secondary font-mono">edicts.yaml</span>
          </div>
          <pre class="p-4 text-sm leading-relaxed"><code class="text-text-primary"><span class="text-text-secondary">version:</span> 1
<span class="text-text-secondary">edicts:</span>
  - <span class="text-text-secondary">text:</span> <span class="text-success">"v2.0 launches April 15"</span>
    <span class="text-text-secondary">category:</span> product
    <span class="text-text-secondary">confidence:</span> verified
  - <span class="text-text-secondary">text:</span> <span class="text-success">"Never mention Project X"</span>
    <span class="text-text-secondary">category:</span> compliance
    <span class="text-text-secondary">confidence:</span> verified</code></pre>
        </div>
      </div>
      <p class="text-text-secondary text-sm text-center mt-4">
        Every agent session automatically receives your edicts as ground truth. No code changes needed.
      </p>
    </div>

    <!-- npm / standalone tab -->
    <div id="panel-npm" class="tab-panel hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Install -->
        <div class="bg-code-bg border border-border-subtle rounded-lg overflow-hidden">
          <div class="px-4 py-2 border-b border-border-subtle">
            <span class="text-xs text-text-secondary font-mono">bash</span>
          </div>
          <pre class="p-4 text-sm leading-relaxed"><code class="text-text-primary"><span class="text-accent">npm</span> install edicts</code></pre>
        </div>

        <!-- Usage -->
        <div class="bg-code-bg border border-border-subtle rounded-lg overflow-hidden">
          <div class="px-4 py-2 border-b border-border-subtle">
            <span class="text-xs text-text-secondary font-mono">typescript</span>
          </div>
          <pre class="p-4 text-sm leading-relaxed"><code class="text-text-primary"><span class="text-accent">import</span> {"{"} EdictStore {"}"} <span class="text-accent">from</span> <span class="text-success">'edicts'</span>;

<span class="text-accent">const</span> store = <span class="text-accent">new</span> EdictStore({"{"}<br/>  path: <span class="text-success">'./edicts.yaml'</span><br/>{"}"});
<span class="text-accent">await</span> store.load();

<span class="text-accent">const</span> rendered = store.render();
<span class="text-text-secondary">// ## Edicts</span>
<span class="text-text-secondary">// - **[product]** v2.0 launches April 15</span>
<span class="text-text-secondary">// - **[compliance]** Never mention Project X</span></code></pre>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
  document.querySelectorAll('.tab-btn').forEach(b => {
    b.classList.remove('tab-active');
    b.classList.add('text-text-secondary');
  });
  document.getElementById('panel-' + tab).classList.remove('hidden');
  const btn = document.getElementById('tab-' + tab);
  btn.classList.add('tab-active');
  btn.classList.remove('text-text-secondary');
}
</script>

<style>
  .tab-active {
    background-color: rgba(212, 175, 55, 0.15);
    color: #d4af37;
  }
</style>
