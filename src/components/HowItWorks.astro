---
const steps = [
  {
    number: '①',
    title: 'Declare',
    text: 'Write verified facts in YAML. 12 tokens per fact.',
    code: `# edicts.yaml
- text: "v2.0 launches April 15"
  confidence: verified`,
  },
  {
    number: '②',
    title: 'Inject',
    text: 'Edicts renders to your prompt automatically. 4K token budget cap.',
    code: `const rendered = store.render();
// → "## Edicts\\n- [product]..."`,
  },
  {
    number: '③',
    title: 'Trust',
    text: 'Every agent sees the same ground truth. Zero hallucination risk.',
    code: `// 5 agents, 1 edicts.yaml
// Same facts. Every session.`,
  },
];
---

<section class="py-20 border-t border-border-subtle">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-12">How it works</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
      {/* Connecting line (desktop only) */}
      <div class="hidden md:block absolute top-12 left-[16.67%] right-[16.67%] h-px bg-border-subtle" aria-hidden="true">
        <div class="absolute left-1/4 top-1/2 -translate-y-1/2 w-2 h-2 bg-accent rounded-full"></div>
        <div class="absolute right-1/4 top-1/2 -translate-y-1/2 w-2 h-2 bg-accent rounded-full"></div>
      </div>

      {steps.map((s) => (
        <div class="bg-bg-surface border border-border-subtle rounded-lg p-6 relative">
          <div class="text-2xl text-accent font-bold mb-2">{s.number}</div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{s.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-4">{s.text}</p>
          <div class="bg-code-bg border border-border-subtle rounded p-3">
            <pre class="text-xs text-text-secondary leading-relaxed overflow-x-auto"><code>{s.code}</code></pre>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
